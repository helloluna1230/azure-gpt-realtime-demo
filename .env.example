# Fill these values before running the demo.
AZURE_OPENAI_ENDPOINT=https://your-resource-name.openai.azure.com/openai/v1
AZURE_OPENAI_API_KEY=your-azure-openai-api-key

# Voice-agent demo deployment.
AZURE_OPENAI_REALTIME_2_DEPLOYMENT=gpt-realtime-2

# Optional: enables [YOU] transcript lines in realtime_2_mic_console.py.
# AZURE_OPENAI_REALTIME_INPUT_TRANSCRIPTION_DEPLOYMENT=gpt-realtime-whisper

# Dedicated translation/transcription demos.
AZURE_OPENAI_TRANSLATE_DEPLOYMENT=gpt-realtime-translate
AZURE_OPENAI_WHISPER_DEPLOYMENT=gpt-realtime-whisper
